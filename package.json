{
  "name": "octopus",
  "productName": "Octopus",
  "private": true,
  "version": "0.1.0",
  "description": "Octopus — every media viewer. Fast Windows desktop viewer for images, video, and audio.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:electron\" \"npm:dev:renderer\" \"npm:dev:start\"",
    "dev:debug": "concurrently -k \"npm:dev:electron\" \"npm:dev:renderer\" \"npm:dev:start:debug\"",
    "dev:electron": "tsc -p tsconfig.electron.json --watch",
    "dev:renderer": "vite",
    "dev:start": "wait-on dist-electron/main.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:start:debug": "wait-on dist-electron/main.js tcp:5173 && cross-env VIEWER_DEBUG=1 VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -b && tsc -p tsconfig.electron.json && vite build",
    "self-check": "node scripts/self-check.mjs",
    "start": "electron .",
    "start:debug": "cross-env VIEWER_DEBUG=1 electron ."
  },
  "dependencies": {
    "ag-psd": "^28.5.0",
    "exifr": "^7.1.3",
    "heic2any": "^0.0.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^10.0.0",
    "electron": "^36.3.1",
    "playwright-core": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  }
}
